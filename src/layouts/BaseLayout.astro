---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Site Factory generated website',
  image,
  noindex = true,
} = Astro.props;

// Site-wide structured data
const organizationData = {
  name: 'Hazel Dell Dentistry',
  url: Astro.site?.href,
  logo: new URL('/images/logo/hazel-dell-dentistry-logo-icon-transparent.png', Astro.site).href,
  image: new URL('/images/logo/hazel-dell-dentistry-logo-icon-transparent.png', Astro.site).href,
  telephone: '+1-317-706-1111',
  email: 'hazeldelloffice@gmail.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '13190 Hazel Dell Pkwy #160',
    addressLocality: 'Carmel',
    addressRegion: 'IN',
    postalCode: '46033',
    addressCountry: 'US',
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday'],
    opens: '07:00',
    closes: '16:00',
  },
  sameAs: [
    'https://www.instagram.com/hazeldelldentistry',
    'https://www.facebook.com/hazeldelldentistry/',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preconnect to external origins (fonts, analytics) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts with font-display: swap for performance -->
    <!-- Playfair Display: wordmark/logo only ("Hazel Dell Dentistry" logotype). PT Serif: headings (h1-h6), body, and nav site-wide. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400&family=PT+Serif:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Complete Favicon Set -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Theme color for browser UI -->
    <meta name="theme-color" content="#ffffff" />

    <!-- SEO Meta Tags (includes Open Graph and Twitter Cards) -->
    <SEOHead
      title={title}
      description={description}
      image={image}
      noindex={noindex}
    />

    <!-- Organization Structured Data (site-wide) -->
    <StructuredData type="LocalBusiness" data={organizationData} />

    <!-- BugHerd — client review widget, remove before launch (see /launch) -->
    <script is:inline type="text/javascript" src="https://www.bugherd.com/sidebarv2.js?apikey=331huictxqcfwcgsfiijja" async="true"></script>
  </head>
  <body class="font-body text-neutral-900 bg-neutral-50 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-primary focus:text-primary-foreground"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>
