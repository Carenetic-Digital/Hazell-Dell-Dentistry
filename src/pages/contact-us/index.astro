---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import StructuredData from '../../components/StructuredData.astro';

const breadcrumbData = {
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Contact Us', item: new URL('/contact-us/', Astro.site).href },
  ],
};
---

<BaseLayout
  title="Contact Us | Hazel Dell Dentistry | Carmel, IN"
  description="Request an appointment or get in touch with Hazel Dell Dentistry in Carmel, IN — call, email, or visit our office."
>
  <StructuredData type="BreadcrumbList" data={breadcrumbData} />

  <Header />

  <main id="main-content">
    <!-- Breadcrumb + Title -->
    <section class="bg-neutral-50 py-12 md:py-16 border-b border-neutral-200">
      <div class="max-w-6xl mx-auto px-4 md:px-8">
        <nav aria-label="Breadcrumb" class="mb-4">
          <ol class="flex flex-wrap items-center gap-2 text-sm text-neutral-600">
            <li><a href="/" class="hover:text-neutral-900 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary rounded-sm">Home</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-neutral-900" aria-current="page">Contact Us</li>
          </ol>
        </nav>
        <h1 class="text-neutral-900 mb-4">Contact Us</h1>
        <p class="text-neutral-600 max-w-2xl">
          Ready to schedule your visit? Reach out or request an appointment below.
        </p>
      </div>
    </section>

    <!-- Contact Info + Form -->
    <section class="bg-neutral-50 py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-4 md:px-8 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <div class="space-y-10">
          <dl class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div>
              <dt class="text-sm uppercase tracking-wide text-neutral-600 mb-2">Our Address</dt>
              <dd class="text-neutral-900">13190 Hazel Dell Pkwy #160<br />Carmel, IN 46033</dd>
            </div>
            <div>
              <dt class="text-sm uppercase tracking-wide text-neutral-600 mb-2">Phone</dt>
              <dd>
                <a href="tel:+13177061111" class="text-neutral-900 hover:text-neutral-600 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary rounded-sm">
                  317-706-1111
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-sm uppercase tracking-wide text-neutral-600 mb-2">Email</dt>
              <dd>
                <a href="mailto:hazeldelloffice@gmail.com" class="text-neutral-900 hover:text-neutral-600 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary rounded-sm">
                  hazeldelloffice@gmail.com
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-sm uppercase tracking-wide text-neutral-600 mb-2">Open Hours</dt>
              <dd class="text-neutral-900">Monday &ndash; Thursday<br />7:00 AM &ndash; 4:00 PM</dd>
            </div>
          </dl>

          <div class="aspect-video w-full border border-neutral-200">
            <iframe
              title="Map showing Hazel Dell Dentistry location in Carmel, IN"
              src="https://www.google.com/maps?q=13190+Hazel+Dell+Pkwy+%23160,+Carmel,+IN+46033&output=embed"
              width="100%"
              height="100%"
              style="border:0"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>

        <!--
          Jotform embed goes here — swap this placeholder for the real embed
          script/iframe once the form is built in Jotform.
          Remember to add form.jotform.com (and any submit.jotform.com /
          cdn.jotfor.ms hosts the embed script needs) to public/_headers'
          CSP script-src/frame-src/connect-src directives — see
          docs/third-party-scripts.md — and use is:inline on the script tag.
        -->
        <div class="border border-dashed border-border-interactive p-8 md:p-10 flex flex-col items-center justify-center text-center gap-3 min-h-80">
          <p class="text-neutral-900 font-display font-bold">Appointment Request Form</p>
          <p class="text-neutral-600 max-w-sm">
            Jotform embed placeholder — swap in the live form embed here before launch.
          </p>
          <p class="text-neutral-600 max-w-sm">
            In the meantime, call <a href="tel:+13177061111" class="underline underline-offset-4 hover:text-neutral-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary rounded-sm">317-706-1111</a> or
            email <a href="mailto:hazeldelloffice@gmail.com" class="underline underline-offset-4 hover:text-neutral-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary rounded-sm">hazeldelloffice@gmail.com</a> to
            request an appointment.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
